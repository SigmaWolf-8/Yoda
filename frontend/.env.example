# YODA Frontend — environment variables
# Copy this file to .env.local for local development.
# In production (Replit Deployments), set these via the Secrets panel.

# ── CRS (Cube Registration Service) ──────────────────────────────────────────
# Required for the "Install & Connect" button on self-hosted engine slots.
# Set to the deployed YODA domain so generated install scripts point to the
# live CRS endpoint instead of localhost.
# Example: https://yoda.example.replit.app
VITE_CRS_URL=
